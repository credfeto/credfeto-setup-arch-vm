#!/bin/sh

tmpfile=$(
    mktemp
) || {
    printf '%s\n' "Failed to create temporary file" >&2
    exit 1
}

if ! curl -fsSL https://raw.githubusercontent.com/credfeto/credfeto-setup-arch-vm/refs/heads/main/install -o "$tmpfile"; then
    printf '%s\n' "Failed to download install script" >&2
    rm -f "$tmpfile"
    exit 1
fi

sh "$tmpfile"
status=$?
rm -f "$tmpfile"
exit "$status"
