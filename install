#!/bin/sh

GREEN='\033[0;32m'
YELLOW='\033[0;33m'
RED='\033[0;31m'
RESET='\033[0m'

ok()   { printf "${GREEN}✓${RESET} %s\n" "$*"; }
skip() { printf "${YELLOW}●${RESET} %s\n" "$*"; }
die()  { printf "${RED}✗${RESET} %s\n" "$*" >&2; exit 1; }

# ============================================================
# Shell environment
# ============================================================

echo "Configuring shell aliases..."
grep -qF "alias ls='ls -aFh --color=always'" "$HOME/.bashrc" || echo "alias ls='ls -aFh --color=always'" >> "$HOME/.bashrc"
grep -qF "alias ll='ls -Fls'" "$HOME/.bashrc" || echo "alias ll='ls -Fls'" >> "$HOME/.bashrc"
ok "Shell aliases configured"

# ============================================================
# Configure pacman.conf
# ============================================================

echo "Configuring pacman.conf..."
grep -qF "CacheServer = https://pacman.markridgwell.com/repo/archlinux/" /etc/pacman.conf || \
  sed -i "s|^Include = /etc/pacman.d/mirrorlist$|Include = /etc/pacman.d/mirrorlist\nCacheServer = https://pacman.markridgwell.com/repo/archlinux/\$repo/os/\$arch|" /etc/pacman.conf || die "Could not update pacman.conf"
ok "pacman.conf configured"

# ============================================================
# Configure Chaotic AUR
# ============================================================

echo "Configuring Chaotic AUR..."
pacman-key --recv-key 3056513887B78AEB --keyserver hkps://keyserver.ubuntu.com || die "Could not receive Chaotic AUR key"
pacman-key --lsign-key 3056513887B78AEB || die "Could not sign Chaotic AUR key"
pacman -U 'https://cdn-mirror.chaotic.cx/chaotic-aur/chaotic-keyring.pkg.tar.zst' --noconfirm --needed || die "Could not install Chaotic AUR keyring"
pacman -U 'https://cdn-mirror.chaotic.cx/chaotic-aur/chaotic-mirrorlist.pkg.tar.zst' --noconfirm --needed || die "Could not install Chaotic AUR mirrorlist"

grep -qF "[chaotic-aur]" /etc/pacman.conf || {
cat << EOF >> /etc/pacman.conf

[chaotic-aur]
Include = /etc/pacman.d/chaotic-mirrorlist
CacheServer = https://pacman.markridgwell.com/repo/chaotic-aur/x86_64
EOF
} || die "Could not update pacman.conf with Chaotic AUR repository"
ok "Chaotic AUR configured"

# ============================================================
# Install packages
# ============================================================

echo "Updating packages..."
pacman -Syu --noconfirm || die "Could not update dist"
ok "Packages updated"

# ============================================================
# Verify linux-hardened kernel
# ============================================================

echo "Checking kernel..."
# Only linux-hardened should be installed — no other kernels (linux, linux-lts, etc.)
OTHER_KERNELS=$(pacman -Qq linux linux-lts linux-zen linux-rt 2>/dev/null || true)
[ -z "$OTHER_KERNELS" ] || die "Non-hardened kernel(s) installed: ${OTHER_KERNELS} — remove them and keep only linux-hardened"
pacman -Qq linux-hardened > /dev/null 2>&1 || die "linux-hardened is not installed"
case "$(uname -r)" in
    *-hardened) ok "Running linux-hardened kernel ($(uname -r))" ;;
    *) die "Not running linux-hardened kernel (uname -r: $(uname -r)) — reboot into linux-hardened first" ;;
esac

echo "Installing packages..."
pacman -S --noconfirm --needed docker docker-compose docker-buildx git firewalld fail2ban pkgstats reflector pacman-contrib openssh logrotate ansible || die "Could not install packages"
ok "Packages installed"

# ============================================================
# Configure reflector
# ============================================================

echo "Configuring reflector..."
cat << EOF > /etc/xdg/reflector/reflector.conf
--save /etc/pacman.d/mirrorlist
--protocol https
--latest 10
--sort rate
EOF

systemctl enable --now reflector.timer
systemctl start reflector.service
ok "reflector configured"

# ============================================================
# Configure Docker
# ============================================================

echo "Configuring Docker..."
RESTART=0
[ -d /etc/docker ] || mkdir -p /etc/docker
DOCKER_DAEMON_EXPECTED=$(cat << 'EOF'
{
  "registry-mirrors": ["https://docker-cache.markridgwell.com"],
  "icc": false,
  "no-new-privileges": true,
  "userland-proxy": false,
  "log-driver": "json-file",
  "log-opts": {
    "max-size": "100m",
    "max-file": "3"
  }
}
EOF
)
if [ -f /etc/docker/daemon.json ] && [ "$(cat /etc/docker/daemon.json)" = "${DOCKER_DAEMON_EXPECTED}" ]; then
    skip "Docker daemon.json already correct"
else
    printf '%s\n' "${DOCKER_DAEMON_EXPECTED}" > /etc/docker/daemon.json || die "Could not write /etc/docker/daemon.json"
    ok "Docker daemon.json configured"
    RESTART=1
fi

echo "Enabling Docker..."
systemctl enable --now docker.socket || die "Could not enable docker.socket"
systemctl enable --now docker || die "Could not enable docker.service"
ok "Docker enabled"

# Remove legacy systemd security drop-in for Docker (package-manager service)
DOCKER_DROPIN="/etc/systemd/system/docker.service.d/security.conf"
if [ -f "${DOCKER_DROPIN}" ]; then
    rm "${DOCKER_DROPIN}" || die "Could not remove ${DOCKER_DROPIN}"
    rmdir "$(dirname "${DOCKER_DROPIN}")" 2>/dev/null || true
    systemctl daemon-reload || die "Could not reload systemd daemon"
    RESTART=1
    ok "Removed legacy Docker systemd security drop-in"
else
    skip "No legacy Docker systemd security drop-in present"
fi

# ============================================================
# Configure firewalld
# ============================================================

echo "Configuring firewalld..."
systemctl enable --now firewalld || die "Could not enable firewalld"

# Allow a TCP/UDP port from all private network ranges (idempotent).
# Covers IPv4 RFC-1918 and IPv6 ULA (fc00::/7) + link-local (fe80::/10).
# Usage: firewalld_allow_private <protocol> <port>
FIREWALLD_CHANGED=0
firewalld_allow_private() {
    _fw_proto="${1}"
    _fw_port="${2}"
    # Remove legacy incorrect 172.16.0.0/20 rule if present (RFC 1918 range is /12)
    _fw_legacy_rule="rule family=\"ipv4\" source address=\"172.16.0.0/20\" port protocol=\"${_fw_proto}\" port=\"${_fw_port}\" accept"
    if firewall-cmd --permanent --query-rich-rule="${_fw_legacy_rule}" > /dev/null 2>&1; then
        firewall-cmd --permanent --remove-rich-rule="${_fw_legacy_rule}" \
            || die "Could not remove legacy firewalld rule for ${_fw_proto}/${_fw_port} from 172.16.0.0/20"
        ok "firewalld: removed legacy ${_fw_proto}/${_fw_port} rule for 172.16.0.0/20"
        FIREWALLD_CHANGED=1
    fi
    for _fw_cidr in "10.0.0.0/8" "192.168.0.0/16" "172.16.0.0/12"; do
        _fw_rule="rule family=\"ipv4\" source address=\"${_fw_cidr}\" port protocol=\"${_fw_proto}\" port=\"${_fw_port}\" accept"
        if firewall-cmd --permanent --query-rich-rule="${_fw_rule}" > /dev/null 2>&1; then
            skip "firewalld: ${_fw_proto}/${_fw_port} from ${_fw_cidr} already allowed"
        else
            firewall-cmd --permanent --add-rich-rule="${_fw_rule}" \
                || die "Could not add firewalld rich rule for ${_fw_proto}/${_fw_port} from ${_fw_cidr}"
            ok "firewalld: ${_fw_proto}/${_fw_port} from ${_fw_cidr} allowed"
            FIREWALLD_CHANGED=1
        fi
    done
    for _fw_cidr6 in "fc00::/7" "fe80::/10"; do
        _fw_rule6="rule family=\"ipv6\" source address=\"${_fw_cidr6}\" port protocol=\"${_fw_proto}\" port=\"${_fw_port}\" accept"
        if firewall-cmd --permanent --query-rich-rule="${_fw_rule6}" > /dev/null 2>&1; then
            skip "firewalld: ${_fw_proto}/${_fw_port} from ${_fw_cidr6} already allowed"
        else
            firewall-cmd --permanent --add-rich-rule="${_fw_rule6}" \
                || die "Could not add firewalld rich rule for ${_fw_proto}/${_fw_port} from ${_fw_cidr6}"
            ok "firewalld: ${_fw_proto}/${_fw_port} from ${_fw_cidr6} allowed"
            FIREWALLD_CHANGED=1
        fi
    done
}

firewalld_allow_private tcp 22

if [ "${FIREWALLD_CHANGED}" = "1" ]; then
    firewall-cmd --reload || die "Could not reload firewalld"
    ok "firewalld reloaded"
else
    skip "firewalld: no changes, reload not needed"
fi

# Remove legacy systemd security drop-in for firewalld (package-manager service)
FIREWALLD_DROPIN="/etc/systemd/system/firewalld.service.d/security.conf"
if [ -f "${FIREWALLD_DROPIN}" ]; then
    rm "${FIREWALLD_DROPIN}" || die "Could not remove ${FIREWALLD_DROPIN}"
    rmdir "$(dirname "${FIREWALLD_DROPIN}")" 2>/dev/null || true
    systemctl daemon-reload || die "Could not reload systemd daemon"
    systemctl restart firewalld || die "Could not restart firewalld.service"
    ok "Removed legacy firewalld systemd security drop-in"
else
    skip "No legacy firewalld systemd security drop-in present"
fi

# ============================================================
# Configure SSH hardening
# ============================================================

echo "Configuring SSH hardening..."
SSHD_CHANGED=0

sshd_set() {
    file="/etc/ssh/sshd_config.d/10-${1}.conf"
    expected="${2} ${3}"
    if [ -f "$file" ] && [ "$(cat "$file")" = "$expected" ]; then
        skip "sshd: ${2} ${3} already set"
    else
        printf '%s\n' "$expected" > "$file" || die "Could not write $file"
        ok "sshd: ${2} ${3}"
        SSHD_CHANGED=1
    fi
}

mkdir -p /etc/ssh/sshd_config.d

# Remove legacy misnamed sshd config file (logingraceime → loginGraceTime typo fix)
SSHD_LEGACY_GRACETIME="/etc/ssh/sshd_config.d/10-logingraceime.conf"
if [ -f "${SSHD_LEGACY_GRACETIME}" ]; then
    rm "${SSHD_LEGACY_GRACETIME}" || die "Could not remove ${SSHD_LEGACY_GRACETIME}"
    SSHD_CHANGED=1
    ok "Removed legacy misnamed sshd config file: 10-logingraceime.conf"
else
    skip "No legacy misnamed sshd config file present"
fi

# Host keys
sshd_set "hostkey-ed25519"          HostKey                  /etc/ssh/ssh_host_ed25519_key
sshd_set "hostkey-rsa"              HostKey                  /etc/ssh/ssh_host_rsa_key

# Key exchange, ciphers, MACs
sshd_set "kexalgorithms"            KexAlgorithms            curve25519-sha256,curve25519-sha256@libssh.org,diffie-hellman-group16-sha512
sshd_set "ciphers"                  Ciphers                  chacha20-poly1305@openssh.com,aes256-gcm@openssh.com,aes128-gcm@openssh.com
sshd_set "macs"                     MACs                     hmac-sha2-512-etm@openssh.com,hmac-sha2-256-etm@openssh.com

# Authentication
sshd_set "pubkeyauthentication"     PubkeyAuthentication     yes
sshd_set "permitemptypasswords"     PermitEmptyPasswords     no
sshd_set "permitrootlogin"          PermitRootLogin          no

# Only disable password auth if at least one user has an authorized_keys file with keys
# — prevents accidental lockout
HAS_AUTHORIZED_KEYS=0
for auth_dir in /root /home/*; do
    auth_file="${auth_dir}/.ssh/authorized_keys"
    [ -f "${auth_file}" ] || continue
    grep -qvE '^\s*(#|$)' "${auth_file}" && HAS_AUTHORIZED_KEYS=1 && break
done
if [ "${HAS_AUTHORIZED_KEYS}" = "1" ]; then
    sshd_set "passwordauthentication"          PasswordAuthentication         no
    sshd_set "kbdinteractiveauthentication"    KbdInteractiveAuthentication   no
    sshd_set "challengeresponseauthentication" ChallengeResponseAuthentication no
else
    skip "sshd: PasswordAuthentication left enabled — no authorized_keys found on this system"
fi

# Session
sshd_set "x11forwarding"            X11Forwarding            no
sshd_set "printmotd"                PrintMotd                no
sshd_set "tcpkeepalive"             TCPKeepAlive             yes
sshd_set "permituserenvironment"    PermitUserEnvironment    no
sshd_set "clientaliveinterval"      ClientAliveInterval      300
sshd_set "clientalivecountmax"      ClientAliveCountMax      2

# Logging
sshd_set "syslogfacility"           SyslogFacility           AUTH
sshd_set "loglevel"                 LogLevel                 VERBOSE

# Rate limiting and access
sshd_set "maxauthtries"             MaxAuthTries             3
sshd_set "maxsessions"              MaxSessions              3
sshd_set "loginGraceTime"           LoginGraceTime           30

# Disable unsafe features
sshd_set "hostbasedauthentication"  HostbasedAuthentication  no
sshd_set "ignorerhosts"             IgnoreRhosts             yes
sshd_set "permittunnel"             PermitTunnel             no
sshd_set "allowagentforwarding"     AllowAgentForwarding     no
sshd_set "gatewayports"             GatewayPorts             no
sshd_set "versionaddendum"          VersionAddendum          none

if [ "$SSHD_CHANGED" = "1" ]; then
    sshd -t || die "SSH config validation failed"
    if systemctl is-active --quiet sshd; then
        systemctl reload sshd || die "Could not reload sshd"
        ok "SSH hardening applied and sshd reloaded"
    else
        skip "sshd is not running — config written but service not started"
    fi
fi

# Remove legacy systemd security drop-in for SSHD (package-manager service)
SSHD_DROPIN="/etc/systemd/system/sshd.service.d/security.conf"
if [ -f "${SSHD_DROPIN}" ]; then
    rm "${SSHD_DROPIN}" || die "Could not remove ${SSHD_DROPIN}"
    rmdir "$(dirname "${SSHD_DROPIN}")" 2>/dev/null || true
    systemctl daemon-reload || die "Could not reload systemd daemon"
    systemctl restart sshd || die "Could not restart sshd.service"
    ok "Removed legacy SSHD systemd security drop-in"
else
    skip "No legacy SSHD systemd security drop-in present"
fi

# ============================================================
# Configure fail2ban
# ============================================================

echo "Configuring fail2ban..."
mkdir -p /etc/fail2ban/jail.d

# Global defaults: 1 h ban time, use firewalld rich-rules as ban action
F2B_DEFAULT="/etc/fail2ban/jail.d/default.local"
F2B_DEFAULT_EXPECTED=$(cat << 'EOF'
[DEFAULT]
bantime = 1h
banaction = firewallcmd-rich-rules
banaction_allports = firewallcmd-allports
EOF
)
if [ -f "${F2B_DEFAULT}" ] && [ "$(cat "${F2B_DEFAULT}")" = "${F2B_DEFAULT_EXPECTED}" ]; then
    skip "fail2ban: default.local already correct"
else
    printf '%s\n' "${F2B_DEFAULT_EXPECTED}" > "${F2B_DEFAULT}" || die "Could not write ${F2B_DEFAULT}"
    ok "fail2ban: default.local written"
fi

# SSH jail: aggressive mode
F2B_SSH="/etc/fail2ban/jail.d/ssh.local"
F2B_SSH_EXPECTED=$(cat << 'EOF'
[sshd]
enabled = true
mode = aggressive
EOF
)
if [ -f "${F2B_SSH}" ] && [ "$(cat "${F2B_SSH}")" = "${F2B_SSH_EXPECTED}" ]; then
    skip "fail2ban: ssh.local already correct"
else
    printf '%s\n' "${F2B_SSH_EXPECTED}" > "${F2B_SSH}" || die "Could not write ${F2B_SSH}"
    ok "fail2ban: ssh.local written"
fi

systemctl enable --now fail2ban || die "Could not enable fail2ban"
ok "fail2ban enabled"

# ============================================================
# Configure pkgstats
# ============================================================

echo "Enabling pkgstats..."
PKGSTATS_WANTS_DIR="/etc/systemd/system/timers.target.wants"
PKGSTATS_LINK="${PKGSTATS_WANTS_DIR}/pkgstats.timer"
if [ -L "${PKGSTATS_LINK}" ]; then
    skip "pkgstats timer already enabled"
else
    mkdir -p "${PKGSTATS_WANTS_DIR}" || die "Failed to create ${PKGSTATS_WANTS_DIR}"
    ln -sf /usr/lib/systemd/system/pkgstats.timer "${PKGSTATS_LINK}" || die "Failed to create pkgstats.timer symlink"
    systemctl daemon-reload || die "systemctl daemon-reload failed"
    systemctl start pkgstats.timer || die "Failed to start pkgstats.timer"
    ok "pkgstats timer enabled"
fi

# ============================================================
# Configure auto-update service
# ============================================================

echo "Configuring auto-update service..."

# ── autoupdate system user ────────────────────────────────────────────────────
# Always present. Has no login shell and no home directory so it cannot be used
# interactively or via SSH. The service always runs as this user regardless of
# whether yay or pacman is the active updater.
if id autoupdate > /dev/null 2>&1; then
    skip "autoupdate user already exists"
else
    useradd --system --no-create-home --shell /usr/sbin/nologin autoupdate \
        || die "Could not create autoupdate user"
    ok "autoupdate user created"
fi

# ── sudoers for autoupdate ────────────────────────────────────────────────────
# Restricted to /usr/bin/pacman only. yay calls sudo pacman internally; the
# pacman-only fallback wrapper also uses sudo pacman. No broad root access needed.
AUTOUPDATE_SUDOERS="/etc/sudoers.d/autoupdate"
AUTOUPDATE_SUDOERS_EXPECTED="autoupdate ALL=(ALL) NOPASSWD: /usr/bin/pacman"
if [ -f "${AUTOUPDATE_SUDOERS}" ] && [ "$(cat "${AUTOUPDATE_SUDOERS}")" = "${AUTOUPDATE_SUDOERS_EXPECTED}" ]; then
    skip "sudoers autoupdate already correct"
else
    printf '%s\n' "${AUTOUPDATE_SUDOERS_EXPECTED}" > "${AUTOUPDATE_SUDOERS}" \
        || die "Could not write ${AUTOUPDATE_SUDOERS}"
    chmod 440 "${AUTOUPDATE_SUDOERS}" || die "Could not chmod ${AUTOUPDATE_SUDOERS}"
    visudo -c -f "${AUTOUPDATE_SUDOERS}" || die "Invalid sudoers file ${AUTOUPDATE_SUDOERS}"
    ok "sudoers autoupdate written"
fi

# ── legacy 01_markr sudoers cleanup ──────────────────────────────────────────
if [ -f /etc/sudoers.d/01_markr ]; then
    rm /etc/sudoers.d/01_markr || die "Could not remove legacy /etc/sudoers.d/01_markr"
    ok "Removed legacy /etc/sudoers.d/01_markr"
else
    skip "No legacy /etc/sudoers.d/01_markr to remove"
fi

# ── wrapper script ────────────────────────────────────────────────────────────
AUTO_UPDATE_SCRIPT="/usr/local/bin/auto-update"
AUTO_UPDATE_SCRIPT_EXPECTED=$(cat << 'EOF'
#!/bin/sh
if [ -x /usr/bin/yay ]; then
    exec yay -Syyu --noconfirm
else
    exec sudo pacman -Syyu --noconfirm
fi
EOF
)
if [ -f "${AUTO_UPDATE_SCRIPT}" ] && [ "$(cat "${AUTO_UPDATE_SCRIPT}")" = "${AUTO_UPDATE_SCRIPT_EXPECTED}" ]; then
    skip "auto-update script already correct"
else
    printf '%s\n' "${AUTO_UPDATE_SCRIPT_EXPECTED}" > "${AUTO_UPDATE_SCRIPT}" \
        || die "Could not write ${AUTO_UPDATE_SCRIPT}"
    chmod 755 "${AUTO_UPDATE_SCRIPT}" || die "Could not chmod ${AUTO_UPDATE_SCRIPT}"
    ok "auto-update script written"
fi

# ── service unit ──────────────────────────────────────────────────────────────
# Always run as autoupdate (nologin system user). The wrapper uses sudo pacman
# when yay is not installed, so root is never needed directly.
AUTO_UPDATE_SERVICE="/etc/systemd/system/auto-update.service"
AUTO_UPDATE_SERVICE_EXPECTED=$(cat << 'EOF'
[Unit]
Description=Run arch-update auto check
After=network-online.target

[Service]
Type=oneshot
User=autoupdate
ExecStart=/usr/local/bin/auto-update
EOF
)
if [ -f "${AUTO_UPDATE_SERVICE}" ] && [ "$(cat "${AUTO_UPDATE_SERVICE}")" = "${AUTO_UPDATE_SERVICE_EXPECTED}" ]; then
    skip "auto-update.service already correct"
else
    printf '%s\n' "${AUTO_UPDATE_SERVICE_EXPECTED}" > "${AUTO_UPDATE_SERVICE}" \
        || die "Could not write ${AUTO_UPDATE_SERVICE}"
    ok "auto-update.service written"
fi

# ── timer unit ────────────────────────────────────────────────────────────────
AUTO_UPDATE_TIMER="/etc/systemd/system/auto-update.timer"
AUTO_UPDATE_TIMER_EXPECTED=$(cat << 'EOF'
[Unit]
Description=Run arch-update auto check at boot and then every hour

[Timer]
OnStartupSec=15
OnUnitActiveSec=1h

[Install]
WantedBy=timers.target
EOF
)
if [ -f "${AUTO_UPDATE_TIMER}" ] && [ "$(cat "${AUTO_UPDATE_TIMER}")" = "${AUTO_UPDATE_TIMER_EXPECTED}" ]; then
    skip "auto-update.timer already correct"
else
    printf '%s\n' "${AUTO_UPDATE_TIMER_EXPECTED}" > "${AUTO_UPDATE_TIMER}" \
        || die "Could not write ${AUTO_UPDATE_TIMER}"
    ok "auto-update.timer written"
fi

systemctl daemon-reload || die "Could not reload systemd daemon"
systemctl enable --now auto-update.timer || die "Could not enable auto-update.timer"
ok "auto-update service configured"

# ============================================================
# Configure paccache cleanup service
# ============================================================

echo "Configuring paccache cleanup service..."
cat << 'EOF' > /etc/systemd/system/paccache-cleanup.service
[Unit]
Description=Clean up old pacman cache entries

[Service]
Type=oneshot
ExecStart=paccache -r
ProtectSystem=full
ProtectHome=true
NoNewPrivileges=true
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true
RestrictRealtime=true
RestrictSUIDSGID=true
EOF

cat << 'EOF' > /etc/systemd/system/paccache-cleanup.timer
[Unit]
Description=Run paccache cleanup once a week

[Timer]
OnCalendar=weekly
Persistent=true

[Install]
WantedBy=timers.target
EOF

systemctl daemon-reload || die "Could not reload systemd daemon"
systemctl enable --now paccache-cleanup.timer || die "Could not enable paccache-cleanup.timer"
ok "paccache cleanup service configured"

# ============================================================
# Configure docker-cleanup service
# ============================================================

echo "Configuring docker-cleanup service..."
cat << 'EOF' > /etc/systemd/system/docker-cleanup.service
[Unit]
Description=Remove unused docker images
After=docker.service
Requires=docker.service

[Service]
Type=oneshot
ExecStart=docker image prune --all --force
ProtectSystem=full
ProtectHome=true
NoNewPrivileges=true
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true
RestrictRealtime=true
RestrictSUIDSGID=true
EOF

cat << 'EOF' > /etc/systemd/system/docker-cleanup.timer
[Unit]
Description=Remove unused docker images weekly

[Timer]
OnCalendar=weekly
Persistent=true

[Install]
WantedBy=timers.target
EOF

systemctl daemon-reload || die "Could not reload systemd daemon"
systemctl enable --now docker-cleanup.timer || die "Could not enable docker-cleanup.timer"
ok "docker-cleanup service configured"

# ============================================================
# Configure logrotate
# ============================================================

echo "Configuring logrotate..."
LOGROTATE_CONF="/etc/logrotate.conf"
LOGROTATE_EXPECTED=$(cat << 'EOF'
# Rotate logs daily
daily

# Keep 2 weeks of logs
rotate 14

# Create new log files after rotating
create

# Compress rotated logs
compress
delaycompress

# Do not error if log file is missing
missingok

# Do not rotate empty log files
notifempty

# Ignore pacman saved files
tabooext + .pacorig .pacnew .pacsave
EOF
)
if [ -f "${LOGROTATE_CONF}" ] && [ "$(cat "${LOGROTATE_CONF}")" = "${LOGROTATE_EXPECTED}" ]; then
    skip "logrotate.conf already correct"
else
    printf '%s\n' "${LOGROTATE_EXPECTED}" > "${LOGROTATE_CONF}" || die "Could not write ${LOGROTATE_CONF}"
    ok "logrotate.conf configured (daily, 14-day retention)"
fi

systemctl enable --now logrotate.timer || die "Could not enable logrotate.timer"
ok "logrotate timer enabled"

echo "Configuring GRUB kernel command line..."
GRUB_PARAMS="panic=20 slab_nomerge slub_debug=FZ init_on_alloc=1 init_on_free=1 pti=on lsm=landlock,lockdown,yama,apparmor,bpf apparmor=1 security=apparmor lockdown=confidentiality hardened_usercopy=on ia32_emulation=0"
GRUB_CHANGED=0

# Fix typo from earlier versions
if grep -q "hardend_usercopy" /etc/default/grub; then
    sed -i 's/hardend_usercopy/hardened_usercopy/g' /etc/default/grub || die "Could not fix hardened_usercopy typo in GRUB config"
    ok "GRUB: fixed hardened_usercopy typo"
    GRUB_CHANGED=1
fi

# Extract current value and build new value in memory, checking only within GRUB_CMDLINE_LINUX
CMDLINE=$(sed -n 's/^GRUB_CMDLINE_LINUX="\(.*\)"$/\1/p' /etc/default/grub)
NEW_CMDLINE="$CMDLINE"

for PARAM in $GRUB_PARAMS; do
    PARAM_KEY="${PARAM%%=*}"
    case " $NEW_CMDLINE " in
        *" ${PARAM_KEY}"*) ;;
        *) NEW_CMDLINE="${NEW_CMDLINE:+$NEW_CMDLINE }${PARAM}"; GRUB_CHANGED=1; ok "GRUB: added ${PARAM}" ;;
    esac
done

if [ "$NEW_CMDLINE" != "$CMDLINE" ]; then
    sed -i "s|^GRUB_CMDLINE_LINUX=\".*\"$|GRUB_CMDLINE_LINUX=\"${NEW_CMDLINE}\"|" /etc/default/grub || die "Could not update GRUB_CMDLINE_LINUX"
fi

if [ "$GRUB_CHANGED" = "1" ]; then
    grub-mkconfig -o /boot/grub/grub.cfg || die "Could not regenerate GRUB config"
    ok "GRUB config regenerated"
fi

# ============================================================
# Configure sysctl hardening
# ============================================================

echo "Configuring sysctl hardening..."
SYSCTL_CHANGED=0

sysctl_set() {
    file="/etc/sysctl.d/10-${1}.conf"
    expected=$(printf '%s=%s\n' "$1" "$2")
    if [ -f "$file" ] && [ "$(cat "$file")" = "$expected" ]; then
        skip "sysctl: ${1}=${2} already set"
    else
        printf '%s\n' "$expected" > "$file" || die "Could not write $file"
        # Some sysctl keys are absent at runtime when the kernel feature is compiled out
        # (e.g. kernel.kexec_load_disabled when CONFIG_KEXEC=n on linux-hardened).
        # In that case write the persistent config only; skip the live apply.
        _sysctl_proc="/proc/sys/$(printf '%s' "$1" | tr '.' '/')"
        if [ -e "$_sysctl_proc" ]; then
            sysctl -w "${1}=${2}" > /dev/null || die "Could not apply sysctl ${1}=${2}"
            ok "sysctl: ${1}=${2}"
        else
            ok "sysctl: ${1}=${2} (persistent only — key not present in running kernel)"
        fi
        SYSCTL_CHANGED=1
    fi
}

sysctl_set kernel.dmesg_restrict                    1
sysctl_set kernel.unprivileged_bpf_disabled         1
sysctl_set net.core.bpf_jit_harden                 2
sysctl_set kernel.kexec_load_disabled               1
sysctl_set kernel.kptr_restrict                     2
sysctl_set kernel.yama.ptrace_scope                 2
sysctl_set kernel.randomize_va_space                2
sysctl_set kernel.sysrq                             0
sysctl_set net.ipv4.tcp_syncookies                  1
sysctl_set net.ipv4.tcp_rfc1337                     1
sysctl_set net.ipv4.conf.default.rp_filter          1
sysctl_set net.ipv4.conf.all.rp_filter              1
sysctl_set net.ipv4.conf.all.accept_redirects       0
sysctl_set net.ipv4.conf.default.accept_redirects   0
sysctl_set net.ipv4.conf.all.secure_redirects       0
sysctl_set net.ipv4.conf.default.secure_redirects   0
sysctl_set net.ipv6.conf.all.accept_redirects       0
sysctl_set net.ipv6.conf.default.accept_redirects   0
sysctl_set net.ipv4.conf.all.send_redirects         0
sysctl_set net.ipv4.conf.default.send_redirects     0
sysctl_set net.ipv4.conf.all.accept_source_route    0
sysctl_set net.ipv4.conf.default.accept_source_route 0
sysctl_set net.ipv6.conf.all.accept_source_route    0
sysctl_set net.ipv6.conf.default.accept_source_route 0
sysctl_set net.ipv6.conf.all.accept_ra              0
sysctl_set net.ipv6.conf.default.accept_ra          0
sysctl_set net.ipv4.icmp_echo_ignore_all            1
sysctl_set net.ipv4.icmp_echo_ignore_broadcasts     1
sysctl_set net.ipv4.icmp_ignore_bogus_error_responses 1
sysctl_set fs.protected_hardlinks                   1
sysctl_set fs.protected_symlinks                    1
sysctl_set fs.protected_regular                     2
sysctl_set fs.protected_fifos                       2
sysctl_set fs.suid_dumpable                         0
sysctl_set kernel.core_uses_pid                     1

# Log packets with impossible/spoofed source addresses (martians); aids intrusion detection
sysctl_set net.ipv4.conf.all.log_martians           1
sysctl_set net.ipv4.conf.default.log_martians       1

# Restrict perf_event_open to CAP_SYS_ADMIN (level 3); linux-hardened sets this by default
# but we make it explicit here to ensure it is enforced even if the default ever changes.
# Reference: https://www.kernel.org/doc/html/latest/admin-guide/perf-security.html
sysctl_set kernel.perf_event_paranoid               3

if [ "$SYSCTL_CHANGED" = "1" ]; then
    sysctl --system || die "Could not apply sysctl settings"
    ok "sysctl settings applied"
fi

# ============================================================
# Disable core dumps via systemd
# ============================================================

echo "Disabling core dumps..."
COREDUMP_CONF="/etc/systemd/system.conf.d/no-core-dumps.conf"
COREDUMP_EXPECTED=$(cat << 'EOF'
[Manager]
DefaultLimitCORE=0
EOF
)
mkdir -p /etc/systemd/system.conf.d
if [ -f "${COREDUMP_CONF}" ] && [ "$(cat "${COREDUMP_CONF}")" = "${COREDUMP_EXPECTED}" ]; then
    skip "core dump config already correct"
else
    printf '%s\n' "${COREDUMP_EXPECTED}" > "${COREDUMP_CONF}" || die "Could not write ${COREDUMP_CONF}"
    ok "core dumps disabled"
fi

# ============================================================
# Harden default umask via /etc/profile.d
# ============================================================

# Sets a restrictive default umask (027) for all login shells:
#   files: 640 (owner rw, group r, others none)
#   dirs:  750 (owner rwx, group rx, others none)
# This reduces the risk of newly created files being world-readable.
echo "Configuring umask hardening..."
UMASK_PROFILE="/etc/profile.d/umask.sh"
UMASK_EXPECTED=$(cat << 'EOF'
#!/bin/sh
umask 027
EOF
)
if [ -f "${UMASK_PROFILE}" ] && [ "$(cat "${UMASK_PROFILE}")" = "${UMASK_EXPECTED}" ]; then
    skip "umask profile already correct"
else
    printf '%s\n' "${UMASK_EXPECTED}" > "${UMASK_PROFILE}" || die "Could not write ${UMASK_PROFILE}"
    chmod 644 "${UMASK_PROFILE}" || die "Could not chmod ${UMASK_PROFILE}"
    ok "umask hardening configured (027)"
fi

# ============================================================
# Blacklist unused/dangerous kernel modules
# ============================================================

echo "Blacklisting kernel modules..."
mkdir -p /etc/modprobe.d

# Write a single-module blacklist file with an explanatory comment.
# Usage: blacklist_module <module> <reason>
blacklist_module() {
    _bm_file="/etc/modprobe.d/blacklist.${1}.conf"
    _bm_expected=$(printf '# %s\nblacklist %s\n' "$2" "$1")
    if [ -f "$_bm_file" ] && [ "$(cat "$_bm_file")" = "$_bm_expected" ]; then
        skip "module blacklist: ${1} already blacklisted"
    else
        printf '%s\n' "$_bm_expected" > "$_bm_file" || die "Could not write $_bm_file"
        ok "module blacklist: ${1} blacklisted"
    fi
    unset _bm_file _bm_expected
}

# Remove legacy monolithic blacklist file created by earlier versions of this script
if [ -f /etc/modprobe.d/blacklist-hardening.conf ]; then
    rm /etc/modprobe.d/blacklist-hardening.conf || die "Could not remove legacy /etc/modprobe.d/blacklist-hardening.conf"
    ok "removed legacy blacklist-hardening.conf"
fi

# Uncommon and dangerous network protocols
blacklist_module dccp      "DCCP (Datagram Congestion Control Protocol) is rarely used in practice and has a history of remote kernel exploits; disabling it reduces the network attack surface"
blacklist_module sctp      "SCTP (Stream Control Transmission Protocol) is not required on standard workloads and has historically contained kernel vulnerabilities that allow privilege escalation"
blacklist_module rds       "RDS (Reliable Datagram Sockets) is unused on standard systems and has had critical privilege escalation vulnerabilities (e.g. CVE-2010-3904)"
blacklist_module tipc      "TIPC (Transparent Inter-Process Communication) is a cluster networking protocol not needed outside HPC or cluster environments; its presence widens the kernel attack surface"
blacklist_module atm       "ATM (Asynchronous Transfer Mode) is a legacy wide-area networking protocol not required on modern systems; disabling it removes an unnecessary kernel subsystem"

# Uncommon filesystems — each reduces the kernel attack surface by preventing
# automatic module loading when a crafted filesystem image is mounted
blacklist_module cramfs    "cramfs is a legacy read-only compressed ROM filesystem; not needed on modern systems and its presence allows kernel code to be triggered by mounting crafted images"
blacklist_module freevxfs  "freevxfs is a legacy Veritas filesystem originating from HP-UX; it is not used on modern Linux systems and disabling it removes an unnecessary attack surface"
blacklist_module jffs2     "JFFS2 is a journalling flash filesystem designed for embedded hardware; not required on standard systems and disabling prevents exploitation via crafted flash images"
blacklist_module hfs       "Apple HFS filesystem support is not required on standard Linux systems; disabling prevents kernel code execution via crafted HFS images (e.g. when auto-mounting removable media)"
blacklist_module hfsplus   "Apple HFS+ filesystem support is not required on standard Linux systems; disabling prevents kernel code execution via crafted HFS+ images (e.g. when auto-mounting removable media)"

# FireWire — physical DMA attack vector
# FireWire (IEEE 1394) grants connected devices direct memory access (DMA),
# bypassing the CPU and OS security controls.  An attacker with physical access
# can read or write arbitrary system memory, extract credentials, or inject code.
blacklist_module firewire_core  "FireWire (IEEE 1394) bus driver; FireWire allows DMA access to system memory by connected devices, enabling cold-boot and physical DMA attacks — disable unless the hardware explicitly requires it"
blacklist_module firewire_ohci  "FireWire OHCI host controller driver; disabled as part of FireWire DMA attack surface reduction (see firewire_core)"
blacklist_module firewire_sbp2  "FireWire SBP-2 storage protocol driver; disabled as part of FireWire DMA attack surface reduction (see firewire_core)"

# HDLC line discipline — exploited in CVE-2017-2636 for local privilege escalation;
# legacy WAN protocol with no use on a Proxmox VM.
# Reference: https://nvd.nist.gov/vuln/detail/CVE-2017-2636
blacklist_module n_hdlc         "HDLC line discipline; disabled due to CVE-2017-2636 privilege-escalation history and no use on a VM"

# Amateur packet radio and legacy WAN protocols — no radio hardware present on a Proxmox VM.
blacklist_module ax25           "AX.25 amateur packet radio protocol; no radio hardware on a Proxmox VM"
blacklist_module netrom         "NET/ROM amateur packet radio protocol; no radio hardware on a Proxmox VM"
blacklist_module x25            "X.25 legacy WAN protocol; no use in a modern VM environment"

# Controller Area Network — industrial/automotive bus absent from virtual machines.
blacklist_module can            "CAN bus protocol; industrial/automotive — absent from a Proxmox VM"

# Virtual Video Test Driver — development/test module; no display hardware on a server VM.
blacklist_module vivid           "Virtual Video Test Driver; development module with no purpose on a headless server"

# USB mass storage — Proxmox VMs have no physical USB storage by default; reduce attack surface.
# Remove this entry if USB passthrough to this VM is intentionally configured.
blacklist_module usb_storage     "USB mass storage driver; no physical USB storage on a Proxmox VM"

# Bluetooth — no Bluetooth hardware on a Proxmox VM.
blacklist_module bluetooth       "Bluetooth subsystem; no Bluetooth hardware on a Proxmox VM"
blacklist_module btusb           "Bluetooth USB driver; no Bluetooth hardware on a Proxmox VM"

# ============================================================
# Harden /tmp with noexec via systemd drop-in
# ============================================================

# Arch Linux mounts /tmp via systemd's tmp.mount (not fstab).
# The correct way to add noexec is a drop-in that overrides the Options.
echo "Hardening /tmp..."
TMP_DROPIN_DIR="/etc/systemd/system/tmp.mount.d"
TMP_DROPIN="${TMP_DROPIN_DIR}/noexec.conf"
TMP_DROPIN_EXPECTED=$(cat << 'EOF'
[Mount]
Options=mode=1777,strictatime,nosuid,nodev,noexec,size=50%,nr_inodes=1m
EOF
)
mkdir -p "${TMP_DROPIN_DIR}"
if [ -f "${TMP_DROPIN}" ] && [ "$(cat "${TMP_DROPIN}")" = "${TMP_DROPIN_EXPECTED}" ]; then
    skip "/tmp noexec drop-in already correct"
else
    printf '%s\n' "${TMP_DROPIN_EXPECTED}" > "${TMP_DROPIN}" || die "Could not write ${TMP_DROPIN}"
    systemctl daemon-reload || die "Could not reload systemd daemon"
    systemctl restart tmp.mount || die "Could not remount /tmp"
    ok "/tmp hardened with noexec"
fi

# ============================================================
# Configure network
# ============================================================

if [ ! -f /etc/systemd/network/eth0.network ]; then
    echo "Configuring network..."

    # Detect the first physical wired NIC. The prefixes eth/enp/ens are exclusively
    # assigned to wired Ethernet by systemd predictable network naming, so this
    # positive match is both precise and VM-friendly (avoids 'type ether' which can
    # miss interfaces on some hypervisors). Wireless (wlan/wlp) and virtual
    # interfaces (docker/br-/veth) are naturally excluded by not matching.
    NIC=$(ip -o link show | awk '/^[0-9]+: (eth|enp|ens)/{sub(/:$/, "", $2); print $2; exit}')
    [ -n "$NIC" ] || die "Could not detect a physical network interface"

    IPV4=$(ip -o -4 addr show dev "$NIC" scope global | awk 'NR==1{print $4}')
    [ -n "$IPV4" ] || die "Could not detect IPv4 address on $NIC"

    GW4=$(ip -4 route show default dev "$NIC" | awk 'NR==1{print $3}')

    IPV6=$(ip -o -6 addr show dev "$NIC" scope global | awk 'NR==1{print $4}')
    GW6=$(ip -6 route show default dev "$NIC" 2>/dev/null | awk 'NR==1{print $3}')

    {
        cat << EOF
[Match]
Name=$NIC

[Link]
RequiredForOnline=routable

[Network]
DNS=192.168.42.251 192.168.42.252 192.168.42.253 192.168.42.254
DNS=2a02:8010:61d5:42::251 2a02:8010:61d5:42::252 2a02:8010:61d5:42::253 2a02:8010:61d5:42::254

[Address]
Address=$IPV4
EOF
        if [ -n "$GW4" ]; then
            cat << EOF

[Route]
Gateway=$GW4
EOF
        fi
        if [ -n "$IPV6" ]; then
            cat << EOF

[Address]
Address=$IPV6
EOF
        fi
        if [ -n "$GW6" ]; then
            cat << EOF

[Route]
Gateway=$GW6
EOF
        fi
    } > /etc/systemd/network/eth0.network
    ok "Network configured"
else
    skip "Network already configured, skipping"
fi

rm -f /etc/resolv.conf
cat << 'EOF' > /etc/resolv.conf
search .

nameserver 192.168.42.251
nameserver 192.168.42.252
nameserver 192.168.42.253
nameserver 192.168.42.254

nameserver 2a02:8010:61d5:42::251
nameserver 2a02:8010:61d5:42::252
nameserver 2a02:8010:61d5:42::253
nameserver 2a02:8010:61d5:42::254

options edns0 trust-ad
EOF
ok "resolv.conf written"

systemctl daemon-reload
[ "$RESTART" = "1" ] && systemctl restart docker
networkctl reload

# ============================================================
# Remove orphaned packages
# ============================================================

echo "Removing orphaned packages..."
ORPHANS=$(pacman -Qdtq 2>/dev/null || true)
if [ -n "${ORPHANS}" ]; then
    printf '%s\n' "${ORPHANS}" | pacman -Rs --noconfirm - || die "Could not remove orphaned packages"
    ok "Orphaned packages removed"
else
    skip "No orphaned packages to remove"
fi

# ============================================================
# Configure ansible-pull for automatic updates
#
# ansible-pull inverts the normal Ansible push model: a systemd timer on the
# managed host periodically runs `ansible-pull`, which checks out the latest
# version of this repository from GitHub and applies the `site.yml` playbook
# (which in turn re-runs this `install` script).  This replaces the old
# `./security` curl-based wrapper with a proper scheduled, pull-based approach.
# ============================================================

echo "Configuring ansible-pull service..."

ANSIBLE_PULL_SERVICE="/etc/systemd/system/ansible-pull.service"
ANSIBLE_PULL_SERVICE_EXPECTED=$(cat << 'EOF'
[Unit]
Description=Ansible Pull - automatic system configuration update
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=/usr/bin/ansible-pull -U https://github.com/credfeto/credfeto-setup-arch-vm.git -C main site.yml
StandardOutput=journal
StandardError=journal
EOF
)
if [ -f "${ANSIBLE_PULL_SERVICE}" ] && [ "$(cat "${ANSIBLE_PULL_SERVICE}")" = "${ANSIBLE_PULL_SERVICE_EXPECTED}" ]; then
    skip "ansible-pull.service already correct"
else
    printf '%s\n' "${ANSIBLE_PULL_SERVICE_EXPECTED}" > "${ANSIBLE_PULL_SERVICE}" || die "Could not write ${ANSIBLE_PULL_SERVICE}"
    ok "ansible-pull.service written"
fi

echo "Configuring ansible-pull timer..."

ANSIBLE_PULL_TIMER="/etc/systemd/system/ansible-pull.timer"
ANSIBLE_PULL_TIMER_EXPECTED=$(cat << 'EOF'
[Unit]
Description=Run ansible-pull every 6 hours to apply latest system configuration
Requires=ansible-pull.service

[Timer]
OnBootSec=5min
OnUnitActiveSec=6h
RandomizedDelaySec=10min
Persistent=true

[Install]
WantedBy=timers.target
EOF
)
if [ -f "${ANSIBLE_PULL_TIMER}" ] && [ "$(cat "${ANSIBLE_PULL_TIMER}")" = "${ANSIBLE_PULL_TIMER_EXPECTED}" ]; then
    skip "ansible-pull.timer already correct"
else
    printf '%s\n' "${ANSIBLE_PULL_TIMER_EXPECTED}" > "${ANSIBLE_PULL_TIMER}" || die "Could not write ${ANSIBLE_PULL_TIMER}"
    ok "ansible-pull.timer written"
fi

systemctl daemon-reload || die "Could not reload systemd daemon after ansible-pull unit changes"
systemctl enable --now ansible-pull.timer || die "Could not enable ansible-pull.timer"
ok "ansible-pull.timer enabled and started"

# ============================================================
# Reboot check
# ============================================================

RUNNING_KERNEL=$(uname -r)
if [ -d "/usr/lib/modules/${RUNNING_KERNEL}" ]; then
    ok "Running kernel ${RUNNING_KERNEL} is current — no reboot needed"
else
    printf "${YELLOW}⚠${RESET} Reboot required: running %s but the kernel has been updated\n" "${RUNNING_KERNEL}"
fi
