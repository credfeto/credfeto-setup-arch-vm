#! /bin/sh

GREEN='\033[0;32m'
YELLOW='\033[0;33m'
RED='\033[0;31m'
RESET='\033[0m'

ok()   { printf "${GREEN}✓${RESET} %s\n" "$*"; }
skip() { printf "${YELLOW}●${RESET} %s\n" "$*"; }
die()  { printf "${RED}✗${RESET} %s\n" "$*" >&2; exit 1; }

# ============================================================
# Shell environment
# ============================================================

echo "Configuring shell aliases..."
grep -qF "alias ls='ls -aFh --color=always'" "$HOME/.bashrc" || echo "alias ls='ls -aFh --color=always'" >> "$HOME/.bashrc"
grep -qF "alias ll='ls -Fls'" "$HOME/.bashrc" || echo "alias ll='ls -Fls'" >> "$HOME/.bashrc"
ok "Shell aliases configured"

# ============================================================
# Configure pacman.conf
# ============================================================

echo "Configuring pacman.conf..."
grep -qF "CacheServer = https://pacman.markridgwell.com/repo/archlinux/" /etc/pacman.conf || \
  sed -i "s|^Include = /etc/pacman.d/mirrorlist$|Include = /etc/pacman.d/mirrorlist\nCacheServer = https://pacman.markridgwell.com/repo/archlinux/\$repo/os/\$arch|" /etc/pacman.conf || die "Could not update pacman.conf"
ok "pacman.conf configured"

# ============================================================
# Configure Chaotic AUR
# ============================================================

echo "Configuring Chaotic AUR..."
pacman-key --recv-key 3056513887B78AEB --keyserver hkps://keyserver.ubuntu.com || die "Could not receive Chaotic AUR key"
pacman-key --lsign-key 3056513887B78AEB || die "Could not sign Chaotic AUR key"
pacman -U 'https://cdn-mirror.chaotic.cx/chaotic-aur/chaotic-keyring.pkg.tar.zst' --noconfirm || die "Could not install Chaotic AUR keyring"
pacman -U 'https://cdn-mirror.chaotic.cx/chaotic-aur/chaotic-mirrorlist.pkg.tar.zst' --noconfirm || die "Could not install Chaotic AUR mirrorlist"

grep -qF "[chaotic-aur]" /etc/pacman.conf || {
cat << EOF >> /etc/pacman.conf

[chaotic-aur]
Include = /etc/pacman.d/chaotic-mirrorlist
CacheServer = https://pacman.markridgwell.com/repo/chaotic-aur/x86_64
EOF
} || die "Could not update pacman.conf with Chaotic AUR repository"
ok "Chaotic AUR configured"

# ============================================================
# Install packages
# ============================================================

echo "Updating packages..."
pacman -Syu --noconfirm || die "Could not update dist"
ok "Packages updated"

# ============================================================
# Verify linux-hardened kernel
# ============================================================

echo "Checking kernel..."
# Only linux-hardened should be installed — no other kernels (linux, linux-lts, etc.)
OTHER_KERNELS=$(pacman -Qq linux linux-lts linux-zen linux-rt 2>/dev/null || true)
[ -z "$OTHER_KERNELS" ] || die "Non-hardened kernel(s) installed: ${OTHER_KERNELS} — remove them and keep only linux-hardened"
pacman -Qq linux-hardened > /dev/null 2>&1 || die "linux-hardened is not installed"
case "$(uname -r)" in
    *-hardened) ok "Running linux-hardened kernel ($(uname -r))" ;;
    *) die "Not running linux-hardened kernel (uname -r: $(uname -r)) — reboot into linux-hardened first" ;;
esac

echo "Installing packages..."
pacman -S --noconfirm --needed docker docker-compose docker-buildx git pigz criu firewalld pkgstats reflector pacman-contrib openssh || die "Could not install packages"
ok "Packages installed"

# ============================================================
# Configure reflector
# ============================================================

echo "Configuring reflector..."
cat << EOF > /etc/xdg/reflector/reflector.conf
--save /etc/pacman.d/mirrorlist
--protocol https
--latest 10
--sort rate
EOF

systemctl enable --now reflector.timer
systemctl start reflector.service
ok "reflector configured"

# ============================================================
# Configure Docker
# ============================================================

echo "Configuring Docker mirror..."
RESTART=0
[ -d /etc/docker ] || mkdir -p /etc/docker
if [ ! -f /etc/docker/daemon.json ]; then
  cat << EOF > /etc/docker/daemon.json
{
   "registry-mirrors" : ["https://docker-cache.markridgwell.com"]
}
EOF
  RESTART=1
fi
ok "Docker mirror configured"

echo "Enabling Docker..."
systemctl enable --now docker.socket || die "Could not enable docker.socket"
systemctl enable --now docker || die "Could not enable docker.service"
ok "Docker enabled"

# ============================================================
# Configure firewalld
# ============================================================

echo "Enabling firewalld..."
systemctl enable --now firewalld
ok "firewalld enabled"

# ============================================================
# Configure SSH hardening
# ============================================================

echo "Configuring SSH hardening..."
SSHD_CHANGED=0

sshd_set() {
    file="/etc/ssh/sshd_config.d/10-${1}.conf"
    expected="${2} ${3}"
    if [ -f "$file" ] && [ "$(cat "$file")" = "$expected" ]; then
        skip "sshd: ${2} ${3} already set"
    else
        printf '%s\n' "$expected" > "$file" || die "Could not write $file"
        ok "sshd: ${2} ${3}"
        SSHD_CHANGED=1
    fi
}

mkdir -p /etc/ssh/sshd_config.d

# Host keys
sshd_set "hostkey-ed25519"          HostKey                  /etc/ssh/ssh_host_ed25519_key
sshd_set "hostkey-rsa"              HostKey                  /etc/ssh/ssh_host_rsa_key

# Key exchange, ciphers, MACs
sshd_set "kexalgorithms"            KexAlgorithms            curve25519-sha256,curve25519-sha256@libssh.org,diffie-hellman-group16-sha512
sshd_set "ciphers"                  Ciphers                  chacha20-poly1305@openssh.com,aes-256-gcm@openssh.com,aes-128-gcm@openssh.com
sshd_set "macs"                     MACs                     hmac-sha2-512-etm@openssh.com,hmac-sha2-256-etm@openssh.com

# Authentication
sshd_set "pubkeyauthentication"     PubkeyAuthentication     yes
sshd_set "permitemptypasswords"     PermitEmptyPasswords     no
sshd_set "permitrootlogin"          PermitRootLogin          no

# Only disable password auth if at least one user has an authorized_keys file with keys
# — prevents accidental lockout
HAS_AUTHORIZED_KEYS=0
for auth_dir in /root /home/*; do
    auth_file="${auth_dir}/.ssh/authorized_keys"
    [ -f "${auth_file}" ] || continue
    grep -qvE '^\s*(#|$)' "${auth_file}" && HAS_AUTHORIZED_KEYS=1 && break
done
if [ "${HAS_AUTHORIZED_KEYS}" = "1" ]; then
    sshd_set "passwordauthentication"          PasswordAuthentication         no
    sshd_set "kbdinteractiveauthentication"    KbdInteractiveAuthentication   no
    sshd_set "challengeresponseauthentication" ChallengeResponseAuthentication no
else
    skip "sshd: PasswordAuthentication left enabled — no authorized_keys found on this system"
fi

# Session
sshd_set "x11forwarding"            X11Forwarding            no
sshd_set "printmotd"                PrintMotd                no
sshd_set "tcpkeepalive"             TCPKeepAlive             yes
sshd_set "permituserenvironment"    PermitUserEnvironment    no
sshd_set "clientaliveinterval"      ClientAliveInterval      300
sshd_set "clientalivecountmax"      ClientAliveCountMax      2

# Logging
sshd_set "syslogfacility"           SyslogFacility           AUTH
sshd_set "loglevel"                 LogLevel                 VERBOSE

# Rate limiting and access
sshd_set "maxauthtries"             MaxAuthTries             3
sshd_set "maxsessions"              MaxSessions              3
sshd_set "logingraceime"            LoginGraceTime           30

# Disable unsafe features
sshd_set "hostbasedauthentication"  HostbasedAuthentication  no
sshd_set "ignorerhosts"             IgnoreRhosts             yes
sshd_set "permittunnel"             PermitTunnel             no
sshd_set "allowagentforwarding"     AllowAgentForwarding     no
sshd_set "gatewayports"             GatewayPorts             no
sshd_set "versionaddendum"          VersionAddendum          none

if [ "$SSHD_CHANGED" = "1" ]; then
    sshd -t || die "SSH config validation failed"
    if systemctl is-active --quiet sshd; then
        systemctl reload sshd || die "Could not reload sshd"
        ok "SSH hardening applied and sshd reloaded"
    else
        skip "sshd is not running — config written but service not started"
    fi
fi

# ============================================================
# Configure pkgstats
# ============================================================

echo "Enabling pkgstats..."
PKGSTATS_WANTS_DIR="/etc/systemd/system/timers.target.wants"
PKGSTATS_LINK="${PKGSTATS_WANTS_DIR}/pkgstats.timer"
if [ -L "${PKGSTATS_LINK}" ]; then
    skip "pkgstats timer already enabled"
else
    mkdir -p "${PKGSTATS_WANTS_DIR}" || die "Failed to create ${PKGSTATS_WANTS_DIR}"
    ln -sf /usr/lib/systemd/system/pkgstats.timer "${PKGSTATS_LINK}" || die "Failed to create pkgstats.timer symlink"
    systemctl daemon-reload || die "systemctl daemon-reload failed"
    systemctl start pkgstats.timer || die "Failed to start pkgstats.timer"
    ok "pkgstats timer enabled"
fi

# ============================================================
# Configure auto-update service
# ============================================================

echo "Configuring auto-update service..."
cat << 'EOF' > /etc/systemd/system/auto-update.service
[Unit]
Description=Run arch-update auto check
After=network-online.target

[Service]
Type=oneshot
ExecStart=pacman -Syyu --noconfirm
EOF

cat << 'EOF' > /etc/systemd/system/auto-update.timer
[Unit]
Description=Run arch-update auto check at boot and then every hour

[Timer]
OnStartupSec=15
OnUnitActiveSec=1h

[Install]
WantedBy=timers.target
EOF

systemctl daemon-reload || die "Could not reload systemd daemon"
systemctl enable --now auto-update.timer || die "Could not enable auto-update.timer"
ok "auto-update service configured"

# ============================================================
# Configure paccache cleanup service
# ============================================================

echo "Configuring paccache cleanup service..."
cat << 'EOF' > /etc/systemd/system/paccache-cleanup.service
[Unit]
Description=Clean up old pacman cache entries

[Service]
Type=oneshot
ExecStart=paccache -r
EOF

cat << 'EOF' > /etc/systemd/system/paccache-cleanup.timer
[Unit]
Description=Run paccache cleanup once a week

[Timer]
OnCalendar=weekly
Persistent=true

[Install]
WantedBy=timers.target
EOF

systemctl daemon-reload || die "Could not reload systemd daemon"
systemctl enable --now paccache-cleanup.timer || die "Could not enable paccache-cleanup.timer"
ok "paccache cleanup service configured"

# ============================================================
# Configure docker-cleanup service
# ============================================================

echo "Configuring docker-cleanup service..."
cat << 'EOF' > /etc/systemd/system/docker-cleanup.service
[Unit]
Description=Remove unused docker images
After=docker.service
Requires=docker.service

[Service]
Type=oneshot
ExecStart=docker image prune --all --force
EOF

cat << 'EOF' > /etc/systemd/system/docker-cleanup.timer
[Unit]
Description=Remove unused docker images weekly

[Timer]
OnCalendar=weekly
Persistent=true

[Install]
WantedBy=timers.target
EOF

systemctl daemon-reload || die "Could not reload systemd daemon"
systemctl enable --now docker-cleanup.timer || die "Could not enable docker-cleanup.timer"
ok "docker-cleanup service configured"

# ============================================================
# Configure GRUB kernel command line
# ============================================================

echo "Configuring GRUB kernel command line..."
GRUB_PARAMS="panic=20 slab_nomerge slub_debug=FZ init_on_alloc=1 init_on_free=1 pti=on lsm=landlock,lockdown,yama,apparmor,bpf apparmor=1 security=apparmor lockdown=confidentiality hardened_usercopy=on ia32_emulation=0"
GRUB_CHANGED=0

# Fix typo from earlier versions
if grep -q "hardend_usercopy" /etc/default/grub; then
    sed -i 's/hardend_usercopy/hardened_usercopy/g' /etc/default/grub || die "Could not fix hardened_usercopy typo in GRUB config"
    ok "GRUB: fixed hardened_usercopy typo"
    GRUB_CHANGED=1
fi

# Extract current value and build new value in memory, checking only within GRUB_CMDLINE_LINUX
CMDLINE=$(sed -n 's/^GRUB_CMDLINE_LINUX="\(.*\)"$/\1/p' /etc/default/grub)
NEW_CMDLINE="$CMDLINE"

for PARAM in $GRUB_PARAMS; do
    PARAM_KEY="${PARAM%%=*}"
    case " $NEW_CMDLINE " in
        *" ${PARAM_KEY}"*) ;;
        *) NEW_CMDLINE="${NEW_CMDLINE:+$NEW_CMDLINE }${PARAM}"; GRUB_CHANGED=1; ok "GRUB: added ${PARAM}" ;;
    esac
done

if [ "$NEW_CMDLINE" != "$CMDLINE" ]; then
    sed -i "s|^GRUB_CMDLINE_LINUX=\".*\"$|GRUB_CMDLINE_LINUX=\"${NEW_CMDLINE}\"|" /etc/default/grub || die "Could not update GRUB_CMDLINE_LINUX"
fi

if [ "$GRUB_CHANGED" = "1" ]; then
    grub-mkconfig -o /boot/grub/grub.cfg || die "Could not regenerate GRUB config"
    ok "GRUB config regenerated"
fi

# ============================================================
# Configure sysctl hardening
# ============================================================

echo "Configuring sysctl hardening..."
SYSCTL_CHANGED=0

sysctl_set() {
    local file="/etc/sysctl.d/10-${1}.conf"
    local expected
    expected=$(printf '%s=%s\n' "$1" "$2")
    if [ -f "$file" ] && [ "$(cat "$file")" = "$expected" ]; then
        skip "sysctl: ${1}=${2} already set"
    else
        printf '%s\n' "$expected" > "$file" || die "Could not write $file"
        ok "sysctl: ${1}=${2}"
        SYSCTL_CHANGED=1
    fi
}

sysctl_set kernel.dmesg_restrict                    1
sysctl_set kernel.unprivileged_bpf_disabled         1
sysctl_set net.core.bpf_jit_harden                 2
sysctl_set kernel.kexec_load_disabled               1
sysctl_set kernel.kptr_restrict                     2
sysctl_set kernel.yama.ptrace_scope                 2
sysctl_set kernel.randomize_va_space                2
sysctl_set kernel.sysrq                             0
sysctl_set net.ipv4.tcp_syncookies                  1
sysctl_set net.ipv4.tcp_rfc1337                     1
sysctl_set net.ipv4.conf.default.rp_filter          1
sysctl_set net.ipv4.conf.all.rp_filter              1
sysctl_set net.ipv4.conf.all.accept_redirects       0
sysctl_set net.ipv4.conf.default.accept_redirects   0
sysctl_set net.ipv4.conf.all.secure_redirects       0
sysctl_set net.ipv4.conf.default.secure_redirects   0
sysctl_set net.ipv6.conf.all.accept_redirects       0
sysctl_set net.ipv6.conf.default.accept_redirects   0
sysctl_set net.ipv4.conf.all.send_redirects         0
sysctl_set net.ipv4.conf.default.send_redirects     0
sysctl_set net.ipv4.conf.all.accept_source_route    0
sysctl_set net.ipv4.conf.default.accept_source_route 0
sysctl_set net.ipv6.conf.all.accept_source_route    0
sysctl_set net.ipv6.conf.default.accept_source_route 0
sysctl_set net.ipv6.conf.all.accept_ra              0
sysctl_set net.ipv6.conf.default.accept_ra          0
sysctl_set net.ipv4.icmp_echo_ignore_all            1
sysctl_set net.ipv4.icmp_echo_ignore_broadcasts     1
sysctl_set net.ipv4.icmp_ignore_bogus_error_responses 1
sysctl_set fs.protected_hardlinks                   1
sysctl_set fs.protected_symlinks                    1
sysctl_set fs.protected_regular                     2
sysctl_set fs.protected_fifos                       2
sysctl_set fs.suid_dumpable                         0
sysctl_set kernel.core_uses_pid                     1

if [ "$SYSCTL_CHANGED" = "1" ]; then
    sysctl --system || die "Could not apply sysctl settings"
    ok "sysctl settings applied"
fi

# ============================================================
# Disable core dumps via systemd
# ============================================================

echo "Disabling core dumps..."
COREDUMP_CONF="/etc/systemd/system.conf.d/no-core-dumps.conf"
COREDUMP_EXPECTED=$(cat << 'EOF'
[Manager]
DefaultLimitCORE=0
EOF
)
mkdir -p /etc/systemd/system.conf.d
if [ -f "${COREDUMP_CONF}" ] && [ "$(cat "${COREDUMP_CONF}")" = "${COREDUMP_EXPECTED}" ]; then
    skip "core dump config already correct"
else
    printf '%s\n' "${COREDUMP_EXPECTED}" > "${COREDUMP_CONF}" || die "Could not write ${COREDUMP_CONF}"
    ok "core dumps disabled"
fi

# ============================================================
# Blacklist unused/dangerous kernel modules
# ============================================================

echo "Blacklisting kernel modules..."
MODPROBE_CONF="/etc/modprobe.d/blacklist-hardening.conf"
MODPROBE_EXPECTED=$(cat << 'EOF'
# Uncommon and dangerous network protocols
blacklist dccp
blacklist sctp
blacklist rds
blacklist tipc
blacklist atm

# Uncommon filesystems
blacklist cramfs
blacklist freevxfs
blacklist jffs2
blacklist hfs
blacklist hfsplus

# Firewire
blacklist firewire_core
blacklist firewire_ohci
blacklist firewire_sbp2
EOF
)
if [ -f "${MODPROBE_CONF}" ] && [ "$(cat "${MODPROBE_CONF}")" = "${MODPROBE_EXPECTED}" ]; then
    skip "kernel module blacklist already correct"
else
    printf '%s\n' "${MODPROBE_EXPECTED}" > "${MODPROBE_CONF}" || die "Could not write ${MODPROBE_CONF}"
    ok "kernel module blacklist configured"
fi

# ============================================================
# Harden /tmp with noexec tmpfs
# ============================================================

echo "Hardening /tmp..."
if grep -qE '^tmpfs\s+/tmp\s+' /etc/fstab; then
    skip "/tmp tmpfs already in fstab"
else
    printf 'tmpfs /tmp tmpfs defaults,rw,nosuid,nodev,noexec,relatime,size=2G 0 0\n' >> /etc/fstab || die "Could not update /etc/fstab for /tmp"
    ok "/tmp tmpfs with noexec added to fstab"
fi

# ============================================================
# Configure network
# ============================================================

if [ ! -f /etc/systemd/network/eth0.network ]; then
    echo "Configuring network..."

    # Detect the first physical NIC (skip loopback, docker bridges, veth pairs)
    NIC=$(ip -o link show type ether | awk '!/docker|br-|veth/{sub(/:$/, "", $2); print $2; exit}')
    [ -n "$NIC" ] || die "Could not detect a physical network interface"

    IPV4=$(ip -o -4 addr show dev "$NIC" scope global | awk 'NR==1{print $4}')
    [ -n "$IPV4" ] || die "Could not detect IPv4 address on $NIC"

    GW4=$(ip -4 route show default dev "$NIC" | awk 'NR==1{print $3}')

    IPV6=$(ip -o -6 addr show dev "$NIC" scope global | awk 'NR==1{print $4}')
    GW6=$(ip -6 route show default dev "$NIC" 2>/dev/null | awk 'NR==1{print $3}')

    {
        cat << EOF
[Match]
Name=$NIC

[Link]
RequiredForOnline=routable

[Network]
DNS=192.168.42.251 192.168.42.252 192.168.42.253 192.168.42.254
DNS=2a02:8010:61d5:42::251 2a02:8010:61d5:42::252 2a02:8010:61d5:42::253 2a02:8010:61d5:42::254

[Address]
Address=$IPV4
EOF
        if [ -n "$GW4" ]; then
            cat << EOF

[Route]
Gateway=$GW4
EOF
        fi
        if [ -n "$IPV6" ]; then
            cat << EOF

[Address]
Address=$IPV6
EOF
        fi
        if [ -n "$GW6" ]; then
            cat << EOF

[Route]
Gateway=$GW6
EOF
        fi
    } > /etc/systemd/network/eth0.network
    ok "Network configured"
else
    skip "Network already configured, skipping"
fi

rm -f /etc/resolv.conf
cat << 'EOF' > /etc/resolv.conf
search .

nameserver 192.168.42.251
nameserver 192.168.42.252
nameserver 192.168.42.253
nameserver 192.168.42.254

nameserver 2a02:8010:61d5:42::251
nameserver 2a02:8010:61d5:42::252
nameserver 2a02:8010:61d5:42::253
nameserver 2a02:8010:61d5:42::254

options edns0 trust-ad
EOF
ok "resolv.conf written"

systemctl daemon-reload
[ "$RESTART" = "1" ] && systemctl restart docker
networkctl reload

ok "Done"
