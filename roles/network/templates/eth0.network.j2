[Match]
Name={{ network_nic.stdout }}

[Link]
RequiredForOnline=routable

[Network]
DNS={{ network_nameservers_ipv4 | join(' ') }}
DNS={{ network_nameservers_ipv6 | join(' ') }}

Address={{ network_ipv4.stdout }}
{% if network_gw4.stdout | length > 0 %}
Gateway={{ network_gw4.stdout }}
{% endif %}
{% if network_ipv6.stdout | length > 0 %}

Address={{ network_ipv6.stdout }}
{% endif %}
{% if network_gw6.stdout | length > 0 %}

Gateway={{ network_gw6.stdout }}
{% endif %}
